                                <color key="textColor" red="0.1176470588" green="0.2784313725" blue="0.4039215686" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="ISLES" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="Sky-Farm-Subtitle">
                                <rect key="frame" x="145" y="576" width="103" height="17"/>
                                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="12"/>
                                <color key="textColor" red="0.2549019608" green="0.5019607843" blue="0.631372549" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="Sky-Farm-Safe-Area"/>
                        <color key="backgroundColor" red="0.8980392157" green="0.9607843137" blue="0.9843137255" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <constraint firstItem="Sky-Farm-Logo-Image" firstAttribute="centerX" secondItem="Sky-Farm-Launch-View" secondAttribute="centerX" id="Sky-Farm-Logo-Center-X"/>
                            <constraint firstItem="Sky-Farm-Logo-Image" firstAttribute="centerY" secondItem="Sky-Farm-Launch-View" secondAttribute="centerY" constant="-68" id="Sky-Farm-Logo-Center-Y"/>
                            <constraint firstItem="Sky-Farm-Title" firstAttribute="top" secondItem="Sky-Farm-Logo-Image" secondAttribute="bottom" constant="23" id="Sky-Farm-Title-Top"/>
