        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <!--Sky Farm Launch Screen-->
        <scene sceneID="Sky-Farm-Launch-Scene">
            <objects>
                <viewController id="Sky-Farm-Launch-Controller" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="Sky-Farm-Launch-View">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="Sky-Farm-Logo-Image">
                                <rect key="frame" x="99.5" y="303.0" width="194" height="194"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="194" id="Sky-Farm-Logo-Width"/>
                                    <constraint firstAttribute="height" constant="194" id="Sky-Farm-Logo-Height"/>
                                </constraints>
                                <imageReference key="image" image="logo-icon"/>
